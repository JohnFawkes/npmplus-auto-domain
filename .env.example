# ============================================================
# NPMplus Auto Domain — environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# Host (and optional port) of your NPMplus instance.
# Do NOT include http:// or https://.
# Examples:
#   192.168.1.10:81
#   npm.yourdomain.com
#   npm.yourdomain.com:81
NPMPLUS_HOST=192.168.1.10:81

# NPMplus admin credentials
NPMPLUS_USER=admin@example.com
NPMPLUS_PASS=changeme

# ------------------------------------------------------------
# Optional
# ------------------------------------------------------------

# Set to "true" if NPMplus is only reachable over HTTPS.
# Self-signed certificates are accepted automatically.
# Default: false
NPMPLUS_HTTPS=false

# Set to "false" to keep proxy hosts in NPMplus even after a
# container stops. They will be re-associated on the next start.
# Default: true
CLEANUP_ON_STOP=true

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO
